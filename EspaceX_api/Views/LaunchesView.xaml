<UserControl x:Class="EspaceX_api.Views.LaunchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">
    <Grid>
        <DockPanel>

            <!-- TOOLBAR -->
            <Border DockPanel.Dock="Top"
                    Background="#080808"
                    Padding="20,12"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#1A1A1A">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Boton Volver -->
                    <Border Background="Transparent"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,7"
                            Margin="0,0,16,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding GoHomeCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="&#x2190; VOLVER"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>

                    <Rectangle Width="1" Fill="#1A1A1A" Margin="0,0,16,0"/>

                    <!-- Cargar -->
                    <Border Background="#FFFFFF"
                            CornerRadius="2"
                            Padding="18,8"
                            Margin="0,0,8,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding LoadLaunchesCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="CARGAR"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Foreground="#000000"/>
                    </Border>

                    <!-- Actualizar -->
                    <Border Background="Transparent"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="18,8"
                            Margin="0,0,24,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding RefreshCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="ACTUALIZAR"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#888888"/>
                    </Border>

                    <Rectangle Width="1" Fill="#1A1A1A" Margin="0,0,16,0"/>

                    <!-- Busqueda -->
                    <TextBlock Text="BUSCAR"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Foreground="#444444"
                               Margin="0,0,10,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0D0D0D"
                             Foreground="#CCCCCC"
                             CaretBrush="#FFFFFF"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1"
                             Padding="10,6"
                             Width="220"
                             Margin="0,0,20,0"
                             FontFamily="Segoe UI"
                             FontSize="11"/>

                    <!-- Estado -->
                    <TextBlock Text="ESTADO"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Foreground="#444444"
                               Margin="0,0,10,0"/>
                    <ComboBox SelectedItem="{Binding StatusFilter}"
                              Width="130"
                              FontFamily="Segoe UI"
                              FontSize="11"
                              IsEditable="False">
                        <ComboBox.Template>
                            <ControlTemplate TargetType="ComboBox">
                                <Grid>
                                    <Border x:Name="MainBorder"
                                            Background="#0D0D0D"
                                            BorderBrush="#2A2A2A"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                        <Grid>
                                            <ContentPresenter x:Name="PART_ContentSite"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              Margin="10,6,28,6"
                                                              VerticalAlignment="Center"
                                                              IsHitTestVisible="False">
                                                <ContentPresenter.Resources>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
                                                </ContentPresenter.Resources>
                                            </ContentPresenter>
                                            <Path x:Name="Arrow"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0"
                                                  Data="M 0 0 L 5 5 L 10 0 Z"
                                                  Fill="#666666"
                                                  IsHitTestVisible="False"/>
                                            <ToggleButton
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                              RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  ClickMode="Press">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                        </Grid>
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           Placement="Bottom"
                                           IsOpen="{TemplateBinding IsDropDownOpen}"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Background="#0D0D0D"
                                                BorderBrush="#2A2A2A"
                                                BorderThickness="1"
                                                MinWidth="{TemplateBinding ActualWidth}"
                                                MaxHeight="200">
                                            <ScrollViewer CanContentScroll="True">
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MainBorder" Property="BorderBrush" Value="#444444"/>
                                    </Trigger>
                                    <Trigger Property="IsDropDownOpen" Value="True">
                                        <Setter TargetName="MainBorder" Property="BorderBrush" Value="#555555"/>
                                        <Setter TargetName="Arrow" Property="Fill" Value="#AAAAAA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ComboBox.Template>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#0D0D0D"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="10,7"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontFamily="{TemplateBinding FontFamily}"
                                                           FontSize="{TemplateBinding FontSize}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#1A1A1A"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#222222"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Todos</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Proximo</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Exitoso</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Fallido</System:String>
                    </ComboBox>
                </WrapPanel>
            </Border>

            <!-- ERROR -->
            <Border DockPanel.Dock="Bottom"
                    Background="#1A0000"
                    BorderBrush="#3A0000"
                    BorderThickness="0,1,0,0"
                    Padding="20,10"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF4444"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- CARGA -->
            <Border DockPanel.Dock="Bottom" Background="#080808" Padding="10,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Cargando misiones..."
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#555555"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- TABLA PRINCIPAL -->
            <DataGrid ItemsSource="{Binding FilteredLaunches}"
                      AutoGenerateColumns="False"
                      Background="#000000"
                      Foreground="#CCCCCC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#111111"
                      RowHeaderWidth="0"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      BorderThickness="0"
                      FontFamily="Segoe UI"
                      FontSize="12">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#080808"/>
                        <Setter Property="Foreground" Value="#444444"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="BorderBrush" Value="#111111"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#000000"/>
                        <Setter Property="Foreground" Value="#BBBBBB"/>
                        <Setter Property="BorderBrush" Value="#0D0D0D"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0A0A0A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#111111"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#BBBBBB"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOMBRE"
                                        Binding="{Binding Name}"
                                        Width="230"/>
                    <DataGridTextColumn Header="FECHA"
                                        Binding="{Binding DateFormatted}"
                                        Width="140"/>

                    <!-- Badge de estado -->
                    <DataGridTemplateColumn Header="ESTADO" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="1"
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        Margin="12,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Exitoso">
                                                    <Setter Property="Background" Value="#0A1A0A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Fallido">
                                                    <Setter Property="Background" Value="#1A0A0A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Proximo">
                                                    <Setter Property="Background" Value="#0A0A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#666666"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Exitoso">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Fallido">
                                                        <Setter Property="Foreground" Value="#FF4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Proximo">
                                                        <Setter Property="Foreground" Value="#5599FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="DETALLES"
                                        Binding="{Binding Details}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Details}"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Grid>
</UserControl>
