<UserControl x:Class="EspaceX_api.Views.MapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">
    <Grid>
        <DockPanel>

            <!-- TOOLBAR -->
            <Border DockPanel.Dock="Top"
                    Background="#080808"
                    Padding="20,12"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#1A1A1A">
                <StackPanel Orientation="Horizontal">

                    <!-- Volver -->
                    <Border Background="Transparent"
                            BorderBrush="#222222"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,7"
                            Margin="0,0,16,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding GoHomeCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="&#x2190; VOLVER"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#555555"/>
                    </Border>

                    <Rectangle Width="1" Fill="#1A1A1A" Margin="0,0,16,0"/>

                    <!-- Cargar sitios -->
                    <Border Background="#FFFFFF"
                            CornerRadius="2"
                            Padding="18,8"
                            Margin="0,0,16,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding LoadLaunchSitesCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="CARGAR SITIOS"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Foreground="#000000"/>
                    </Border>

                    <Rectangle Width="1" Fill="#1A1A1A" Margin="0,0,16,0"/>

                    <!-- Zoom controls -->
                    <Border Background="Transparent"
                            BorderBrush="#222222"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="12,7"
                            Margin="0,0,4,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ZoomInCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="ZOOM +"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>

                    <Border Background="Transparent"
                            BorderBrush="#222222"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="12,7"
                            Margin="0,0,4,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ZoomOutCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="ZOOM -"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>

                    <Border Background="Transparent"
                            BorderBrush="#222222"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="12,7"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ResetViewCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="RESET"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ERROR -->
            <Border DockPanel.Dock="Top"
                    Background="#1A0000"
                    BorderBrush="#3A0000"
                    BorderThickness="0,0,0,1"
                    Padding="20,10"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF4444"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- CONTENIDO PRINCIPAL: mapa + sidebar -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- CANVAS DEL MAPA -->
                <Grid Grid.Column="0">
                    <Canvas x:Name="MapCanvas"
                            Background="#040810"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ClipToBounds="True"/>

                    <!-- Overlay de carga -->
                    <Border Background="#AA000000">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="CARGANDO SITIOS"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True"
                                         Width="200" Height="2"
                                         Margin="0,16,0,0"
                                         Foreground="#FFFFFF"
                                         Background="#1A1A1A"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SIDEBAR -->
                <Border Grid.Column="1"
                        Background="#060606"
                        BorderThickness="1,0,0,0"
                        BorderBrush="#111111">
                    <DockPanel>

                        <!-- Titulo sidebar -->
                        <Border DockPanel.Dock="Top"
                                Background="#080808"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#111111"
                                Padding="16,12">
                            <TextBlock Text="SITIOS DE LANZAMIENTO"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#444444"/>
                        </Border>

                        <!-- Footer: lanzamientos del sitio -->
                        <Border DockPanel.Dock="Bottom"
                                Background="#050505"
                                BorderThickness="0,1,0,0"
                                BorderBrush="#111111"
                                Padding="12,8">
                            <TextBlock Text="LANZAMIENTOS DEL SITIO"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>
                        </Border>

                        <!-- Tabla lanzamientos del sitio -->
                        <DataGrid DockPanel.Dock="Bottom"
                                  ItemsSource="{Binding SelectedSiteLaunches}"
                                  AutoGenerateColumns="False"
                                  Background="#060606"
                                  Foreground="#AAAAAA"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#0D0D0D"
                                  RowHeaderWidth="0"
                                  CanUserAddRows="False"
                                  Height="180"
                                  FontFamily="Segoe UI"
                                  FontSize="11"
                                  BorderThickness="0"
                                  IsReadOnly="True">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#080808"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderBrush" Value="#111111"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#060606"/>
                                    <Setter Property="BorderBrush" Value="#0D0D0D"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#0A0A0A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#0D0D0D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NOMBRE"
                                                    Binding="{Binding Name}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="FECHA"
                                                    Binding="{Binding DateUtc, StringFormat='{}{0:dd/MM/yy}'}"
                                                    Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Lista de sitios -->
                        <ListBox ItemsSource="{Binding LaunchSites}"
                                 SelectedItem="{Binding SelectedSite}"
                                 Background="#060606"
                                 Foreground="#AAAAAA"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"
                                            Padding="14,12"
                                            Margin="0"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="#111111">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="Segoe UI Semibold"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#DDDDDD"/>
                                            <TextBlock Text="{Binding Info}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="10"
                                                       Foreground="#444444"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bg"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#0D0D0D"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#0A0A0A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                    </DockPanel>
                </Border>

            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
