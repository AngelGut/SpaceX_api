<UserControl x:Class="EspaceX_api.Views.MapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a1a">
    <Grid>
        <DockPanel>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="#333333" Padding="15"
                    BorderThickness="0,0,0,1" BorderBrush="#0066cc">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding LoadLaunchSitesCommand}"
                            Background="#0066cc" Foreground="White"
                            Padding="15,8" FontWeight="Bold" Margin="0,0,10,0">
                        Cargar Sitios
                    </Button>
                    <Button Command="{Binding ZoomInCommand}"
                            Background="#444444" Foreground="White"
                            Padding="10,8" FontWeight="Bold" Margin="0,0,5,0">
                        Zoom +
                    </Button>
                    <Button Command="{Binding ZoomOutCommand}"
                            Background="#444444" Foreground="White"
                            Padding="10,8" FontWeight="Bold" Margin="0,0,5,0">
                        Zoom -
                    </Button>
                    <Button Command="{Binding ResetViewCommand}"
                            Background="#444444" Foreground="White"
                            Padding="10,8" FontWeight="Bold">
                        Reset
                    </Button>
                </StackPanel>
            </Border>

            <!-- Error Message -->
            <Border DockPanel.Dock="Top" Background="#cc0000" Padding="10,5"
                    Visibility="{Binding ErrorMessage,
                                 Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White" FontWeight="Bold"/>
            </Border>

            <!-- Main Content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Canvas del mapa -->
                <Canvas Grid.Column="0" Background="#0a0a0a" x:Name="MapCanvas"/>

                <!-- Sidebar -->
                <Border Grid.Column="1" Background="#2a2a2a"
                        BorderThickness="1,0,0,0" BorderBrush="#444444">
                    <DockPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="Sitios de Lanzamiento"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="White" Padding="15,10"/>

                        <Border DockPanel.Dock="Bottom" Background="#1a1a1a"
                                Padding="10,8" BorderThickness="0,1,0,0"
                                BorderBrush="#555555">
                            <TextBlock Text="Lanzamientos del sitio seleccionado"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>

                        <DataGrid DockPanel.Dock="Bottom"
                                  ItemsSource="{Binding SelectedSiteLaunches}"
                                  AutoGenerateColumns="False"
                                  Background="#2a2a2a" Foreground="White"
                                  GridLinesVisibility="None"
                                  RowHeaderWidth="0" CanUserAddRows="False"
                                  Height="200" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre"
                                                    Binding="{Binding Name}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Fecha"
                                                    Binding="{Binding DateUtc, StringFormat='{}{0:dd/MM/yy}'}"
                                                    Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <ListBox ItemsSource="{Binding LaunchSites}"
                                 SelectedItem="{Binding SelectedSite}"
                                 Background="#2a2a2a" Foreground="White"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#333333" Padding="10"
                                            Margin="5,3" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Info}"
                                                       FontSize="11"
                                                       Foreground="#aaaaaa"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>