<UserControl x:Class="EspaceX_api.Views.RocketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">
    <Grid>
        <DockPanel>

            <!-- HEADER: titulo tipo "MISSION CONTROL" -->
            <Border DockPanel.Dock="Top"
                    Background="#050505"
                    Height="60"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#1A1A1A"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Rectangle Width="3" Fill="#FFFFFF" Margin="0,0,16,0" VerticalAlignment="Stretch" Height="28"/>
                        <StackPanel>
                            <TextBlock Text="SPACEX MISSION CONTROL"
                                       FontFamily="Segoe UI"
                                       FontSize="9"
                                       Foreground="#444444"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="ROCKET FLEET"
                                       FontFamily="Segoe UI Black"
                                       FontSize="16"
                                       Foreground="#FFFFFF"
                                       FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Indicador NOMINAL -->
                    <Border Grid.Column="2"
                            Background="#050F05"
                            BorderBrush="#1A3A1A"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,6"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6"
                                     Fill="#4CAF50"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="SYSTEMS NOMINAL"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- TOOLBAR -->
            <Border DockPanel.Dock="Top"
                    Background="#000000"
                    Padding="20,10"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#111111">
                <StackPanel Orientation="Horizontal">

                    <!-- Volver -->
                    <Border Background="Transparent"
                            BorderBrush="#222222"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,7"
                            Margin="0,0,16,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding GoHomeCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="&#x2190; VOLVER"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#555555"/>
                    </Border>

                    <Rectangle Width="1" Fill="#1A1A1A" Margin="0,0,16,0"/>

                    <!-- Cargar -->
                    <Border Background="#FFFFFF"
                            CornerRadius="2"
                            Padding="18,8"
                            Margin="0,0,8,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding LoadRocketsCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="CARGAR"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Foreground="#000000"/>
                    </Border>

                    <!-- Actualizar -->
                    <Border Background="Transparent"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="18,8"
                            Margin="0,0,16,0"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding RefreshCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="ACTUALIZAR"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#666666"/>
                    </Border>

                    <Rectangle Width="1" Fill="#1A1A1A" Margin="0,0,16,0"/>

                    <Border Background="#0A0A0A"
                            BorderBrush="#1A1A1A"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="FLOTA SPACEX"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Foreground="#333333"/>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ERROR -->
            <Border DockPanel.Dock="Bottom"
                    Background="#1A0000"
                    BorderBrush="#3A0000"
                    BorderThickness="0,1,0,0"
                    Padding="20,10"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF4444"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- TABLA COHETES -->
            <DataGrid ItemsSource="{Binding Rockets}"
                      SelectedItem="{Binding SelectedRocket}"
                      AutoGenerateColumns="False"
                      Background="#000000"
                      Foreground="#CCCCCC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#0D0D0D"
                      RowHeaderWidth="0"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      BorderThickness="0"
                      ColumnHeaderHeight="38"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      RowHeight="52">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#060606"/>
                        <Setter Property="Foreground" Value="#444444"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="BorderBrush" Value="#111111"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#000000"/>
                        <Setter Property="BorderBrush" Value="#0D0D0D"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0D0D0D"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#080808"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="#AAAAAA"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOMBRE"
                                        Binding="{Binding Name}"
                                        Width="160"/>
                    <DataGridTextColumn Header="TIPO"
                                        Binding="{Binding Type}"
                                        Width="110"/>

                    <!-- Estado con badge -->
                    <DataGridTemplateColumn Header="ESTADO" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Margin="16,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Status}"/>
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Foreground" Value="#555555"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Activo">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Inactivo">
                                                    <Setter Property="Foreground" Value="#FF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="1ER VUELO"
                                        Binding="{Binding FirstFlight}"
                                        Width="110"/>
                    <DataGridTextColumn Header="ALTURA"
                                        Binding="{Binding HeightFormatted}"
                                        Width="130"/>
                    <DataGridTextColumn Header="MASA"
                                        Binding="{Binding MassFormatted}"
                                        Width="120"/>
                    <DataGridTextColumn Header="TASA EXITO"
                                        Binding="{Binding SuccessRatePct, StringFormat='{}{0:F1}%'}"
                                        Width="110"/>
                    <DataGridTextColumn Header="COSTO"
                                        Binding="{Binding CostFormatted}"
                                        Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

        </DockPanel>
    </Grid>
</UserControl>
