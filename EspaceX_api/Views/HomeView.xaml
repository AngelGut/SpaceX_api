<UserControl x:Class="EspaceX_api.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a1a">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="White"
                       TextAlignment="Center"/>
            <TextBlock Text="{Binding Subtitle}" 
                       FontSize="16" 
                       Foreground="#cccccc"
                       TextAlignment="Center"
                       Margin="0,10,0,30"/>
            
            <Border Height="2" Background="#0066cc" Margin="0,0,0,30"/>
            
            <Grid Width="600">
                <StackPanel Spacing="15">
                    <!-- Botón Lanzamientos -->
                    <Border Background="#333333" Padding="20" CornerRadius="5" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" 
                                         Command="{Binding DataContext.NavigateToLaunchesCommand, 
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="🛸 Lanzamientos" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Consulta el historial completo de lanzamientos de SpaceX" 
                                       FontSize="12" 
                                       Foreground="#cccccc"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Botón Cohetes -->
                    <Border Background="#333333" Padding="20" CornerRadius="5" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" 
                                         Command="{Binding DataContext.NavigateToRocketsCommand, 
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="🚀 Cohetes" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Conoce las especificaciones técnicas de los cohetes" 
                                       FontSize="12" 
                                       Foreground="#cccccc"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Botón Mapa -->
                    <Border Background="#333333" Padding="20" CornerRadius="5" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" 
                                         Command="{Binding DataContext.NavigateToMapCommand, 
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="🌍 Mapa de Lanzamientos" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Visualiza los sitios de lanzamiento en un mapa interactivo" 
                                       FontSize="12" 
                                       Foreground="#cccccc"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
