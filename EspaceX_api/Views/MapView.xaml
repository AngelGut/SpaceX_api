<UserControl x:Class="EspaceX_api.MapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a1a">
    <Grid>
        <DockPanel>
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="#333333" Padding="15" BorderThickness="0,0,0,1" BorderBrush="#0066cc">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding LoadLaunchSitesCommand}" 
                            Background="#0066cc" 
                            Foreground="White" 
                            Padding="15,8"
                            FontWeight="Bold">
                        📥 Cargar Sitios
                    </Button>
                    <Separator Background="#555555"/>
                    <Button Command="{Binding ZoomInCommand}" 
                            Background="#444444" 
                            Foreground="White" 
                            Padding="10,8"
                            FontWeight="Bold">
                        🔍 +
                    </Button>
                    <Button Command="{Binding ZoomOutCommand}" 
                            Background="#444444" 
                            Foreground="White" 
                            Padding="10,8"
                            FontWeight="Bold">
                        🔍 -
                    </Button>
                    <Button Command="{Binding ResetViewCommand}" 
                            Background="#444444" 
                            Foreground="White" 
                            Padding="10,8"
                            FontWeight="Bold">
                        ↺
                    </Button>
                </StackPanel>
            </Border>

            <!-- Main Content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Canvas para dibujar el mapa -->
                <Canvas Grid.Column="0" Background="#0a0a0a" x:Name="MapCanvas"/>

                <!-- Sidebar con lista de sitios -->
                <Border Grid.Column="1" Background="#2a2a2a" BorderThickness="1,0,0,0" BorderBrush="#444444">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" 
                                   Text="Sitios de Lanzamiento" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Padding="15,10"/>
                        
                        <ListBox ItemsSource="{Binding LaunchSites}"
                                 SelectedItem="{Binding SelectedSite}"
                                 Background="#2a2a2a"
                                 Foreground="White"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#333333" Padding="10" Margin="5" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Info}" FontSize="11" Foreground="#cccccc"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border DockPanel.Dock="Bottom" Background="#333333" Padding="10" BorderThickness="0,1,0,0" BorderBrush="#555555">
                            <TextBlock Text="Lanzamientos del sitio" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        
                        <DataGrid ItemsSource="{Binding SelectedSiteLaunches}"
                                  AutoGenerateColumns="False"
                                  Background="#2a2a2a"
                                  Foreground="White"
                                  GridLinesVisibility="None"
                                  RowHeaderWidth="0"
                                  CanUserAddRows="False"
                                  FontSize="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
