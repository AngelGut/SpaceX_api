<UserControl x:Class="EspaceX_api.Views.LaunchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a1a">
    <Grid>
        <DockPanel>

            <!-- Toolbar superior -->
            <Border DockPanel.Dock="Top" Background="#333333" Padding="15"
                    BorderThickness="0,0,0,1" BorderBrush="#0066cc">
                <WrapPanel Orientation="Horizontal">

                    <!-- Boton volver al Home -->
                    <Button Command="{Binding GoHomeCommand}"
                            Background="Transparent" Foreground="#8aafc8"
                            BorderBrush="#555577" BorderThickness="1"
                            Padding="12,7" FontWeight="Bold" Margin="0,0,12,0"
                            Cursor="Hand">
                        &#x2190; Volver
                    </Button>
                    <Separator Background="#555555" Width="1" Margin="0,0,12,0"/>

                    <Button Command="{Binding LoadLaunchesCommand}"
                            Background="#0066cc" Foreground="White"
                            Padding="15,8" FontWeight="Bold" Margin="0,0,8,0">
                        Cargar
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Background="#004499" Foreground="White"
                            Padding="15,8" FontWeight="Bold" Margin="0,0,15,0">
                        Actualizar
                    </Button>
                    <Separator Background="#555555" Width="1" Margin="0,0,15,0"/>

                    <!-- Filtro de busqueda por texto -->
                    <TextBlock Text="Busqueda:" VerticalAlignment="Center"
                               Foreground="#aaaaaa" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#444444" Foreground="White"
                             CaretBrush="White" Padding="8,6"
                             Width="250" Margin="0,0,15,0" BorderBrush="#555555"/>

                    <!-- Filtro de estado -->
                    <TextBlock Text="Estado:" VerticalAlignment="Center"
                               Foreground="#aaaaaa" Margin="0,0,8,0"/>
                    <ComboBox SelectedItem="{Binding StatusFilter}"
                              Background="#444444" Foreground="White" Width="150">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                             Color="#444444"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                             Color="#0066cc"/>
                        </ComboBox.Resources>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Todos</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Proximo</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Exitoso</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Fallido</System:String>
                    </ComboBox>
                </WrapPanel>
            </Border>

            <!-- Mensaje de error: visible solo cuando ErrorMessage tiene contenido -->
            <Border DockPanel.Dock="Bottom" Background="#cc3333" Padding="12"
                    Visibility="{Binding ErrorMessage,
                                 Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="White"
                           TextWrapping="Wrap" FontWeight="SemiBold"/>
            </Border>

            <!-- Indicador de carga: visible solo cuando IsLoading es true -->
            <Border DockPanel.Dock="Bottom" Background="#333333" Padding="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Cargando lanzamientos..." Foreground="#0099ff"
                           HorizontalAlignment="Center" FontWeight="Bold"/>
            </Border>

            <!-- Tabla principal de lanzamientos -->
            <DataGrid ItemsSource="{Binding FilteredLaunches}"
                      AutoGenerateColumns="False"
                      Background="#2a2a2a" Foreground="White"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3a3a3a"
                      RowHeaderWidth="0" CanUserAddRows="False"
                      IsReadOnly="True" SelectionMode="Single" BorderThickness="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#222222"/>
                        <Setter Property="Foreground" Value="#0099ff"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="#444444"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#2a2a2a"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a4a"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#004488"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Name}" Width="230"/>
                    <DataGridTextColumn Header="Fecha"
                                        Binding="{Binding DateFormatted}" Width="140"/>

                    <!-- Columna Estado con badge de color segun valor -->
                    <DataGridTemplateColumn Header="Estado" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,3"
                                        HorizontalAlignment="Left" Margin="5,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#555555"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Exitoso">
                                                    <Setter Property="Background" Value="#1a6e2e"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Fallido">
                                                    <Setter Property="Background" Value="#7a1a1a"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Proximo">
                                                    <Setter Property="Background" Value="#1a4a7a"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Detalles"
                                        Binding="{Binding Details}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Details}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Grid>
</UserControl>