<UserControl x:Class="EspaceX_api.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000"
             Loaded="HomeView_Loaded">

    <Grid>
        <!-- FONDO: estrellas generadas en code-behind -->
        <Canvas x:Name="StarsCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>

        <!-- COHETES ANIMADOS - gestionados desde code-behind con DispatcherTimer -->
        <Canvas x:Name="RocketsCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ClipToBounds="True"/>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center">

                <!-- Marca superior -->
                <StackPanel Margin="0,0,0,52" HorizontalAlignment="Center">
                    <Rectangle Height="1" Width="340" Margin="0,0,0,30">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#FFFFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <TextBlock Text="{Binding Title}"
                               FontFamily="Segoe UI Light"
                               FontSize="54"
                               FontWeight="Light"
                               Foreground="#FFFFFF"
                               TextAlignment="Center"/>

                    <TextBlock Text="{Binding Subtitle}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Foreground="#666666"
                               TextAlignment="Center"
                               Margin="0,12,0,0"/>

                    <Rectangle Height="1" Width="340" Margin="0,30,0,0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#FFFFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </StackPanel>

                <!-- Cards de navegacion - estilo SpaceX minimalista -->
                <StackPanel Width="540">

                    <!-- Card: Lanzamientos -->
                    <Border Background="#0D0D0D"
                            BorderBrush="#1F1F1F"
                            BorderThickness="1"
                            Padding="28,22"
                            Margin="0,0,0,2"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding GoToLaunchesCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#0D0D0D"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#141414"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Accent bar izquierdo -->
                            <Rectangle Grid.Column="0" Width="2" Fill="#FFFFFF"
                                       Margin="0,0,20,0" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="LANZAMIENTOS"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="12"
                                           Foreground="#FFFFFF"/>
                                <TextBlock Text="Historial completo de misiones SpaceX"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Foreground="#4A4A4A"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="&#x2192;"
                                       FontSize="16"
                                       Foreground="#333333"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Card: Cohetes -->
                    <Border Background="#0D0D0D"
                            BorderBrush="#1F1F1F"
                            BorderThickness="1"
                            Padding="28,22"
                            Margin="0,0,0,2"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding GoToRocketsCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#0D0D0D"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#141414"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Width="2" Fill="#FFFFFF"
                                       Margin="0,0,20,0" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="COHETES"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="12"
                                           Foreground="#FFFFFF"/>
                                <TextBlock Text="Especificaciones tecnicas de la flota"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Foreground="#4A4A4A"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="&#x2192;"
                                       FontSize="16"
                                       Foreground="#333333"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Card: Mapa -->
                    <Border Background="#0D0D0D"
                            BorderBrush="#1F1F1F"
                            BorderThickness="1"
                            Padding="28,22"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding GoToMapCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#0D0D0D"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#141414"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Width="2" Fill="#FFFFFF"
                                       Margin="0,0,20,0" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="MAPA DE LANZAMIENTOS"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="12"
                                           Foreground="#FFFFFF"/>
                                <TextBlock Text="Sitios de lanzamiento en mapa interactivo"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Foreground="#4A4A4A"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="&#x2192;"
                                       FontSize="16"
                                       Foreground="#333333"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
