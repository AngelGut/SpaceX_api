<UserControl x:Class="EspaceX_api.RocketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a1a">
    <Grid>
        <DockPanel>
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="#333333" Padding="15" BorderThickness="0,0,0,1" BorderBrush="#0066cc">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding LoadRocketsCommand}" 
                            Background="#0066cc" 
                            Foreground="White" 
                            Padding="15,8"
                            FontWeight="Bold">
                        📥 Cargar
                    </Button>
                    <Button Command="{Binding RefreshCommand}" 
                            Background="#0066cc" 
                            Foreground="White" 
                            Padding="15,8"
                            FontWeight="Bold">
                        🔄 Actualizar
                    </Button>
                </StackPanel>
            </Border>

            <!-- Error Message -->
            <Border DockPanel.Dock="Bottom" Background="#ff6666" Padding="15"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding Rockets}"
                      SelectedItem="{Binding SelectedRocket}"
                      AutoGenerateColumns="False"
                      Background="#2a2a2a"
                      Foreground="White"
                      GridLinesVisibility="Horizontal"
                      GridLinesBrush="#444444"
                      RowHeaderWidth="0"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="150"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="120"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Primer vuelo" Binding="{Binding FirstFlight}" Width="120"/>
                    <DataGridTextColumn Header="Altura" Binding="{Binding HeightFormatted}" Width="130"/>
                    <DataGridTextColumn Header="Masa" Binding="{Binding MassFormatted}" Width="120"/>
                    <DataGridTextColumn Header="Tasa éxito" Binding="{Binding SuccessRatePct, StringFormat='{0:F1}%'}" Width="100"/>
                    <DataGridTextColumn Header="Costo" Binding="{Binding CostFormatted}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
