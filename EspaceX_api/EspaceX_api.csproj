<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>EspaceX_api</AssemblyName>
    <RootNamespace>EspaceX_api</RootNamespace>
    <Version>3.0.0</Version>
    <Authors>Tu Nombre</Authors>
    <Description>Aplicación WPF para explorar datos de SpaceX con arquitectura limpia y SOLID</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- MVVM Community Toolkit -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    
    <!-- Dependency Injection -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
  </ItemGroup>

</Project>
